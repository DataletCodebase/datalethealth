<IfModule mod_rewrite.c>
  RewriteEngine On
  # Ensure the base path matches the Vite config base URL
  RewriteBase /
  
  # If the requested file is index.html, don't rewrite it again
  RewriteRule ^index\.html$ - [L]
  
  # If the requested file or directory does not exist
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Rewrite all other requests to index.html to allow React Router to handle it
  RewriteRule . /index.html [L]
</IfModule>
